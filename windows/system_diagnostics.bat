setlocal EnableExtensions

set "OUTDIR=%~dp0"
set "REPORT=%OUTDIR%\report.txt"
set "MSINFO=%OUTDIR%\msinfo.txt"
set "DXDIAG=%OUTDIR%\dxdiag.txt"
set "GPHTML=%OUTDIR%\gpresult.html"
set "BATHTML=%OUTDIR%\batteryreport.html"
set "ENHTML=%OUTDIR%\energyreport.html"
set "WU_LOG=%OUTDIR%\WindowsUpdateLog.txt

> "%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo Windows Diagnostic Report
>>"%REPORT%" echo Computer: %COMPUTERNAME%
>>"%REPORT%" echo Date: %DATE% %TIME%

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Display Windows version information.
>>"%REPORT%" echo COMMAND: ver
ver >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Display current user security token details (groups, privileges, SIDs).
>>"%REPORT%" echo COMMAND: whoami /all
whoami /all >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Dump all environment variables.
>>"%REPORT%" echo COMMAND: set
set >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Display host name.
>>"%REPORT%" echo COMMAND: hostname
hostname >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Show detailed system configuration summary.
>>"%REPORT%" echo COMMAND: systeminfo
systeminfo >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: List installed hotfixes/updates (QFE).
>>"%REPORT%" echo COMMAND: wmic qfe list full /format:table
wmic qfe list full /format:table >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Generate MSINFO32 report file.
>>"%REPORT%" echo COMMAND: msinfo32 /report "%MSINFO%"
msinfo32 /report "%MSINFO%" >nul 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Append MSINFO32 report contents into the main report.
>>"%REPORT%" echo COMMAND: type "%MSINFO%"
type "%MSINFO%" >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Delete temporary MSINFO32 report file.
>>"%REPORT%" echo COMMAND: del "%MSINFO%"
del "%MSINFO%" >nul 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Query Windows CurrentVersion registry information.
>>"%REPORT%" echo COMMAND: reg query "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion"
reg query "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion" >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Dump Boot Configuration Data (BCD) entries.
>>"%REPORT%" echo COMMAND: bcdedit /enum all
bcdedit /enum all >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: List running services (friendly view).
>>"%REPORT%" echo COMMAND: net start
net start >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: List all services and their states.
>>"%REPORT%" echo COMMAND: sc query type= service state= all
sc query type= service state= all >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: List scheduled tasks (verbose).
>>"%REPORT%" echo COMMAND: schtasks /query /fo LIST /v
schtasks /query /fo LIST /v >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Show Group Policy results (summary).
>>"%REPORT%" echo COMMAND: gpresult /r
gpresult /r >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Generate Group Policy HTML report.
>>"%REPORT%" echo COMMAND: gpresult /h "%GPHTML%"
gpresult /h "%GPHTML%" >nul 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Check DISM component store health (quick).
>>"%REPORT%" echo COMMAND: dism /online /cleanup-image /checkhealth
dism /online /cleanup-image /checkhealth >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Scan DISM component store health (detailed).
>>"%REPORT%" echo COMMAND: dism /online /cleanup-image /scanhealth
dism /online /cleanup-image /scanhealth >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 01_System: Verify system file integrity (no repair).
>>"%REPORT%" echo COMMAND: sfc /verifyonly
sfc /verifyonly >>"%REPORT%" 2>&1


>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 02_Hardware: Show CPU details.
>>"%REPORT%" echo COMMAND: wmic cpu get * /format:list
wmic cpu get * /format:list >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 02_Hardware: Show physical memory (DIMM) details.
>>"%REPORT%" echo COMMAND: wmic memorychip get * /format:list
wmic memorychip get * /format:list >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 02_Hardware: Show computer system details (manufacturer/model/etc.).
>>"%REPORT%" echo COMMAND: wmic computersystem get * /format:list
wmic computersystem get * /format:list >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 02_Hardware: Show BIOS details.
>>"%REPORT%" echo COMMAND: wmic bios get * /format:list
wmic bios get * /format:list >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 02_Hardware: Show baseboard/motherboard details.
>>"%REPORT%" echo COMMAND: wmic baseboard get * /format:list
wmic baseboard get * /format:list >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 02_Hardware: Enumerate connected devices via PnPUtil.
>>"%REPORT%" echo COMMAND: pnputil /enum-devices /connected
pnputil /enum-devices /connected >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 02_Hardware: Enumerate devices with problems via PnPUtil.
>>"%REPORT%" echo COMMAND: pnputil /enum-devices /problem
pnputil /enum-devices /problem >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 02_Hardware: Generate DXDIAG text output file.
>>"%REPORT%" echo COMMAND: dxdiag /t "%DXDIAG%"
dxdiag /t "%DXDIAG%" >nul 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 02_Hardware: Append DXDIAG output into the main report.
>>"%REPORT%" echo COMMAND: type "%DXDIAG%"
type "%DXDIAG%" >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 02_Hardware: Delete temporary DXDIAG output file.
>>"%REPORT%" echo COMMAND: del "%DXDIAG%"
del "%DXDIAG%" >nul 2>&1


>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 03_Drivers: List drivers (verbose).
>>"%REPORT%" echo COMMAND: driverquery /v
driverquery /v >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 03_Drivers: List installed/signed driver details.
>>"%REPORT%" echo COMMAND: driverquery /si
driverquery /si >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 03_Drivers: Enumerate driver packages via PnPUtil.
>>"%REPORT%" echo COMMAND: pnputil /enum-drivers
pnputil /enum-drivers >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 03_Drivers: Show Driver Verifier current configuration.
>>"%REPORT%" echo COMMAND: verifier /query
verifier /query >>"%REPORT%" 2>&1


>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 04_Storage: Show physical disk information.
>>"%REPORT%" echo COMMAND: wmic diskdrive get * /format:list
wmic diskdrive get * /format:list >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 04_Storage: Show logical disk information.
>>"%REPORT%" echo COMMAND: wmic logicaldisk get * /format:list
wmic logicaldisk get * /format:list >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 04_Storage: Show volume information.
>>"%REPORT%" echo COMMAND: wmic volume get * /format:list
wmic volume get * /format:list >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 04_Storage: Use DiskPart to list disks, volumes, and partitions.
>>"%REPORT%" echo COMMAND: cmd /c "(echo list disk & echo list volume & echo list partition) | diskpart"
cmd /c "(echo list disk & echo list volume & echo list partition) | diskpart" >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 04_Storage: Show mount points and volume GUID paths.
>>"%REPORT%" echo COMMAND: mountvol
mountvol >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 04_Storage: Show BitLocker status for all volumes.
>>"%REPORT%" echo COMMAND: manage-bde -status
manage-bde -status >>"%REPORT%" 2>&1


>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 05_Network: Show full network adapter configuration.
>>"%REPORT%" echo COMMAND: ipconfig /all
ipconfig /all >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 05_Network: Show ARP cache.
>>"%REPORT%" echo COMMAND: arp -a
arp -a >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 05_Network: Show MAC addresses with details.
>>"%REPORT%" echo COMMAND: getmac /v
getmac /v >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 05_Network: Show routing table.
>>"%REPORT%" echo COMMAND: route print
route print >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 05_Network: Show active connections and listeners with owning process (may require admin).
>>"%REPORT%" echo COMMAND: netstat -abno
netstat -abno >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 05_Network: Show global TCP settings.
>>"%REPORT%" echo COMMAND: netsh int tcp show global
netsh int tcp show global >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 05_Network: Show Winsock catalog.
>>"%REPORT%" echo COMMAND: netsh winsock show catalog
netsh winsock show catalog >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 05_Network: Test DNS resolution for microsoft.com.
>>"%REPORT%" echo COMMAND: nslookup microsoft.com
nslookup microsoft.com >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 05_Network: Ping 8.8.8.8 four times.
>>"%REPORT%" echo COMMAND: ping -n 4 8.8.8.8
ping -n 4 8.8.8.8 >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 05_Network: Traceroute to 8.8.8.8 without name resolution.
>>"%REPORT%" echo COMMAND: tracert -d 8.8.8.8
tracert -d 8.8.8.8 >>"%REPORT%" 2>&1


>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 06_Security: Show firewall settings for all profiles.
>>"%REPORT%" echo COMMAND: netsh advfirewall show allprofiles
netsh advfirewall show allprofiles >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 06_Security: List local user accounts.
>>"%REPORT%" echo COMMAND: net user
net user >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 06_Security: List local groups.
>>"%REPORT%" echo COMMAND: net localgroup
net localgroup >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 06_Security: List members of local Administrators group.
>>"%REPORT%" echo COMMAND: net localgroup administrators
net localgroup administrators >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 06_Security: Show Windows Defender status via PowerShell (if cmdlets available).
>>"%REPORT%" echo COMMAND: powershell -NoProfile -Command "Try { Get-MpComputerStatus | Format-List * } Catch { 'Defender cmdlets unavailable' }"
powershell -NoProfile -Command "Try { Get-MpComputerStatus | Format-List * } Catch { 'Defender cmdlets unavailable' }" >>"%REPORT%" 2>&1


>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 07_Logs: Dump last 300 System event log entries (newest first).
>>"%REPORT%" echo COMMAND: wevtutil qe System /c:300 /rd:true /f:text
wevtutil qe System /c:300 /rd:true /f:text >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 07_Logs: Dump last 300 Application event log entries (newest first).
>>"%REPORT%" echo COMMAND: wevtutil qe Application /c:300 /rd:true /f:text
wevtutil qe Application /c:300 /rd:true /f:text >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 07_Logs: Append CBS.log (Component-Based Servicing) into the report.
>>"%REPORT%" echo COMMAND: type "%windir%\Logs\CBS\CBS.log"
type "%windir%\Logs\CBS\CBS.log" >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 07_Logs: Append DISM log into the report.
>>"%REPORT%" echo COMMAND: type "%windir%\Logs\DISM\dism.log"
type "%windir%\Logs\DISM\dism.log" >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 07_Logs: Generate Windows Update log (PowerShell) into a file.
>>"%REPORT%" echo COMMAND: powershell -NoProfile -Command "Try { Get-WindowsUpdateLog -LogPath '%WU_LOG%' } Catch {}"
powershell -NoProfile -Command "Try { Get-WindowsUpdateLog -LogPath '%WU_LOG%' } Catch {}" >nul 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 07_Logs: Append generated Windows Update log file into the report.
>>"%REPORT%" echo COMMAND: type "%WU_LOG%"
type "%WU_LOG%" >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 07_Logs: Delete temporary Windows Update log file.
>>"%REPORT%" echo COMMAND: del "%WU_LOG%"
del "%WU_LOG%" >nul 2>&1


>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 08_Apps: Enumerate installed applications (machine-wide uninstall keys).
>>"%REPORT%" echo COMMAND: reg query "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall" /s
reg query "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall" /s >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 08_Apps: Enumerate installed applications (per-user uninstall keys).
>>"%REPORT%" echo COMMAND: reg query "HKCU\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall" /s
reg query "HKCU\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall" /s >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 08_Apps: List AppX packages (Store apps) with versions.
>>"%REPORT%" echo COMMAND: powershell -NoProfile -Command "Get-AppxPackage | Select Name,Version | Format-Table -Auto"
powershell -NoProfile -Command "Get-AppxPackage | Select Name,Version | Format-Table -Auto" >>"%REPORT%" 2>&1


>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 09_Performance: List running processes (verbose).
>>"%REPORT%" echo COMMAND: tasklist /v
tasklist /v >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 09_Performance: Dump full process details via WMIC (can be large).
>>"%REPORT%" echo COMMAND: wmic process list full
wmic process list full >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 09_Performance: Show available sleep states.
>>"%REPORT%" echo COMMAND: powercfg /a
powercfg /a >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 09_Performance: Generate battery report HTML.
>>"%REPORT%" echo COMMAND: powercfg /batteryreport /output "%BATHTML%"
powercfg /batteryreport /output "%BATHTML%" >nul 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 09_Performance: Generate energy report HTML.
>>"%REPORT%" echo COMMAND: powercfg /energy /output "%ENHTML%"
powercfg /energy /output "%ENHTML%" >nul 2>&1


>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 10_Crash: List files under %SystemRoot%\Minidump (crash dumps).
>>"%REPORT%" echo COMMAND: dir "%SystemRoot%\Minidump" /a /s
dir "%SystemRoot%\Minidump" /a /s >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 10_Crash: List Windows Error Reporting queued reports.
>>"%REPORT%" echo COMMAND: dir "%ProgramData%\Microsoft\Windows\WER\ReportQueue" /a /s
dir "%ProgramData%\Microsoft\Windows\WER\ReportQueue" /a /s >>"%REPORT%" 2>&1


>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 11_WindowsUpdate: Check Windows Update service state.
>>"%REPORT%" echo COMMAND: sc query wuauserv
sc query wuauserv >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 11_WindowsUpdate: Check BITS service state.
>>"%REPORT%" echo COMMAND: sc query bits
sc query bits >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DESCRIPTION 11_WindowsUpdate: Check Delivery Optimization service state.
>>"%REPORT%" echo COMMAND: sc query dosvc
sc query dosvc >>"%REPORT%" 2>&1

>>"%REPORT%" echo ===========================================================================================================================================================================================================================================================================================================
>>"%REPORT%" echo DONE

echo Done.
echo Report: %REPORT%
echo Output folder: %OUTDIR%

endlocal